# ── Company Sentiment Dashboard — Environment Variables ──────────────────────
# Copy this file to .env and fill in your real keys.
# Never commit .env to version control.

# Reddit (free OAuth app — create at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=SentimentDashboard/1.0

# GNews (free tier — 100 req/day — sign up at https://gnews.io)
GNEWS_API_KEY=your_gnews_api_key_here

# Alpha Vantage (free tier — 25 req/day — sign up at https://alphavantage.co)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
